generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Brand {
  id                  Int       @id @default(autoincrement())
  name                String    @unique
  slug                String    @unique
  logoKey             String?
  coverKey            String?
  shortDescription    String?
  fullDescription     String?
  website             String?
  originCountry       String?
  markets             String?   // JSON array
  shippingRegions     String?   // JSON array
  paymentMethods      String?   // JSON array
  returnPolicy        String?
  supportContact      String?
  socialLinks         String?   // JSON object
  isVerified          Boolean   @default(false)
  publicationStatus   String    @default("draft") // draft|pending|published|paused|rejected
  claimStatus         String    @default("unclaimed") // unclaimed|requested|claimed|suspended
  claimedById         Int?
  claimedBy           User?     @relation("ClaimedBrands", fields: [claimedById], references: [id])
  profileCompleteness Int       @default(0)
  displayOrder        Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  products          Product[]
  brandCategories   BrandCategory[]
  attributeValues   BrandAttributeValue[]
  visits            VisitLog[]
  claims            Claim[]
  submissions       Submission[]

  @@index([publicationStatus])
  @@index([claimStatus])
  @@index([isVerified])
  @@index([originCountry])
}

model Category {
  id           Int       @id @default(autoincrement())
  name         String    @unique
  slug         String    @unique
  parentId     Int?
  parent       Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[] @relation("CategoryTree")
  description  String?
  heroImageKey String?
  seoIntro     String?
  displayOrder Int       @default(0)
  status       String    @default("active") // active|inactive
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  brandCategories   BrandCategory[]
  categoryAttributes CategoryAttribute[]
}

model BrandCategory {
  brandId    Int
  brand      Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  isPrimary  Boolean  @default(false)

  @@id([brandId, categoryId])
}

model Product {
  id           Int      @id @default(autoincrement())
  brandId      Int
  brand        Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name         String
  slug         String   @unique
  description  String?
  imageKey     String?
  price        String?
  productUrl   String?
  displayOrder Int      @default(0)
  status       String   @default("active") // active|inactive
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([brandId])
}

model Attribute {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  slug         String   @unique
  fieldType    String   // text|number|dropdown|radio|checkbox|multi-select|boolean|range
  options      String?  // JSON array for selectable types
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  categoryAttributes CategoryAttribute[]
  attributeValues    BrandAttributeValue[]
}

model CategoryAttribute {
  id          Int       @id @default(autoincrement())
  categoryId  Int
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attributeId Int
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([attributeId])
}

model BrandAttributeValue {
  id          Int       @id @default(autoincrement())
  brandId     Int
  brand       Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  attributeId Int
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String?

  @@index([brandId])
  @@index([attributeId])
}

model Submission {
  id               Int      @id @default(autoincrement())
  type             String   // brand_submission|brand_request|report
  data             String   // JSON
  normalizedDomain String?
  status           String   @default("new") // new|reviewing|approved|rejected|needs_info
  reviewerId       Int?
  reviewerNotes    String?
  createdBrandId   Int?
  createdBrand     Brand?   @relation(fields: [createdBrandId], references: [id])
  submitterEmail   String?
  submitterIp      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([normalizedDomain])
}

model Claim {
  id           Int      @id @default(autoincrement())
  brandId      Int
  brand        Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String
  contactName  String
  contactEmail String
  contactPhone String?
  evidence     String?  // JSON
  status       String   @default("pending") // pending|approved|rejected|needs_info|revoked
  reviewerId   Int?
  reviewerNotes String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([brandId])
  @@index([userId])
}

model VisitLog {
  id          Int      @id @default(autoincrement())
  brandId     Int
  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  visitorIp   String
  userAgent   String?
  referrerUrl String?
  createdAt   DateTime @default(now())

  @@index([brandId])
  @@index([createdAt])
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  objectType String
  objectId   Int
  details    String?  // JSON
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([objectType])
}

model User {
  id            Int       @id @default(autoincrement())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("consumer") // consumer|merchant|moderator|editor|admin
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  claimedBrands  Brand[]      @relation("ClaimedBrands")
  claims         Claim[]
  activityLogs   ActivityLog[]

  @@index([email])
  @@index([role])
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            Int
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
